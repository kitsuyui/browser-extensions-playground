{
  "name": "@kitsuyui/browser-extensions-scraping-server",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "license": "MIT",
  "author": "Yui Kitsu <kitsuyui@kitsuyui.com>",
  "description": "Unified HTTP and WebSocket server for browser scraping workflows",
  "scripts": {
    "build": "prisma generate && tsdown",
    "dev": "tsdown --no-clean --watch",
    "start": "node ./dist/cli.mjs",
    "test": "vitest run",
    "validate": "validate-package-exports --check"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kitsuyui/browser-extensions-playground.git"
  },
  "exports": {
    ".": {
      "require": {
        "type": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "type": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "files": [
    "dist",
    "package.json"
  ],
  "dependencies": {
    "@prisma/client": "^6.16.3",
    "@kitsuyui/browser-extensions-scraping-platform": "workspace:*",
    "ws": "^8.20.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "prisma": "^6.16.3"
  }
}
