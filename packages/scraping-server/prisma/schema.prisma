generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model DeterministicSnapshotRecord {
  id           Int      @id @default(autoincrement())
  provider     String
  snapshotJson String
  receivedAt   DateTime @default(now())

  @@index([provider, receivedAt])
}
