{
  "name": "@kitsuyui/browser-extensions-scraping-devtools",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "license": "MIT",
  "author": "Yui Kitsu <kitsuyui@kitsuyui.com>",
  "description": "Development-only helpers for inspecting captured scraped data",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --no-clean --watch",
    "inspect": "node ./dist/cli.mjs",
    "mcp": "node ./dist/mcp.mjs",
    "test": "vitest run",
    "validate": "validate-package-exports --check"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kitsuyui/browser-extensions-playground.git"
  },
  "exports": {
    ".": {
      "require": {
        "type": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "type": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "main": "dist/index.mjs",
  "bin": {
    "scraping-devtools-mcp": "./dist/mcp.mjs"
  },
  "types": "dist/index.d.mts",
  "files": [
    "dist",
    "package.json"
  ],
  "dependencies": {
    "@kitsuyui/browser-extensions-scraping-platform": "workspace:*",
    "@kitsuyui/browser-extensions-scraping-server": "workspace:*"
  }
}
