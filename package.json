{
  "name": "@kitsuyui/browser-extensions-playground",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "author": "Yui Kitsu <kitsuyui@kitsuyui.com>",
  "description": "A playground for browser extension experiments",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --workspaces --if-present --sequential build",
    "dev": "bun run --workspaces --if-present --parallel dev",
    "format": "biome check --write ./",
    "lint": "biome check ./",
    "prisma:generate": "cd packages/scraping-server && bunx prisma generate",
    "playwright:test": "bun run --filter @kitsuyui/browser-extensions-scraping-extension-devtools build && bun run --filter @kitsuyui/browser-extensions-quota-openai build && bun run --filter @kitsuyui/browser-extensions-example-com build && playwright test",
    "check-module-isolation": "find packages -type d -name src -print -exec bunx ts-module-isolation -- {} +",
    "test": "bun run prisma:generate && vitest run --coverage",
    "validate": "bun run --workspaces --if-present --sequential validate",
    "typecheck": "bun run prisma:generate && tsc --strict -p tsconfig.json --noEmit --skipLibCheck --downlevelIteration",
    "typedoc": "typedoc --treatValidationWarningsAsErrors --treatWarningsAsErrors",
    "typedoc:server": "python3 -m http.server --directory build/typedocs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.2",
    "esbuild": "^0.25.11",
    "@playwright/test": "^1.56.1",
    "@swc/core": "^1.13.5",
    "@types/node": "^24.6.1",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "4.0.18",
    "ts-module-isolation": "^1.0.2",
    "tsdown": "^0.20.0",
    "typedoc": "^0.28.14",
    "typescript": "^5.9.3",
    "validate-package-exports": "^0.18.0",
    "vitest": "^4.0.4"
  },
  "packageManager": "bun@1.3.11",
  "dependencies": {
    "ws": "^8.20.0"
  }
}
